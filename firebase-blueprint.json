{
  "entities": {
    "ClinicalRecord": {
      "title": "ClinicalRecord",
      "description": "A dental clinical record or appointment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "data": { "type": "string", "format": "date" },
        "paciente": { "type": "string" },
        "procedimento": { "type": "string" },
        "dentista": { "type": "string" },
        "status": { "type": "string", "enum": ["Realizado", "Agendado", "Cancelado", "Pendente"] },
        "statusPagamento": { "type": "string", "enum": ["Pago", "Pendente", "Atrasado"] },
        "valor": { "type": "number" }
      },
      "required": ["id", "data", "paciente", "procedimento", "dentista", "status", "statusPagamento", "valor"]
    },
    "AppUser": {
      "title": "AppUser",
      "description": "A system user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "modules": { "type": "string" },
        "username": { "type": "string" },
        "password": { "type": "string" }
      },
      "required": ["id", "name", "role", "modules", "username", "password"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification alert for users",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "error", "success"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "message", "type", "read", "createdAt"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "A technical support ticket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Pendente", "Em Analise", "Resolvido"] },
        "assignedTo": { "type": "string" },
        "assignedToName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userAgent": { "type": "string" }
      },
      "required": ["id", "userId", "description", "status", "createdAt"]
    },
    "Patient": {
      "title": "Patient",
      "description": "A patient record with contact info",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "cpf": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "createdAt"]
    },
    "Document": {
      "title": "Document",
      "description": "A clinical document such as a certificate or prescription",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["Atestado", "Receita", "Exame", "Outro"] },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "dentistId": { "type": "string" },
        "dentistName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "required": ["id", "type", "patientName", "content", "createdAt"]
    }
  },
  "firestore": {
    "/records/{recordId}": {
      "schema": "ClinicalRecord",
      "description": "Collection of dental records"
    },
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Collection of patient contact info"
    },
    "/documents/{documentId}": {
      "schema": "Document",
      "description": "Collection of clinical documents"
    },
    "/users/{userId}": {
      "schema": "AppUser",
      "description": "Collection of application users"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/support_tickets/{ticketId}": {
      "schema": "SupportTicket",
      "description": "Technical support tickets"
    }
  }
}
